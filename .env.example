# ─── Gemini mode (default) ───────────────────────────────────
# Uncomment and fill in GEMINI_API_KEY to use Gemini.
# Provider__Mode=Gemini
# GEMINI_API_KEY=your-gemini-api-key-here
# Provider__GeminiModels__0=gemini-3-flash-preview
# Provider__GeminiModels__1=gemini-3.1-flash-lite-preview
# Provider__GeminiModels__2=gemini-3.1-pro-preview
# Provider__GeminiModels__3=gemini-2.5-flash
# Provider__GeminiModels__4=gemini-2.5-pro
# Provider__GeminiModels__5=gemini-2.0-flash

# ─── Local LLM mode ─────────────────────────────────────────
# Uncomment to use a local OpenAI-compatible server (LM Studio, Ollama, etc.)
# Provider__Mode=Local
# Provider__LocalEndpoint=http://localhost:1234/v1
# Provider__LocalModel=zai-org/glm-4.7-flash

# ─── OTEL (optional) ────────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:6006/v1
# OTEL_SERVICE_NAME=fhir-copilot
