@baseUrl = http://localhost:5075

# ─────────────────────────────────────────────
# System
# ─────────────────────────────────────────────

### Health check
GET {{baseUrl}}/health

### Welcome page
GET {{baseUrl}}/

# ─────────────────────────────────────────────
# Lookup Agent
# ─────────────────────────────────────────────

### Lookup – patient coverage
POST {{baseUrl}}/api/copilot
Content-Type: application/json

{
  "query": "What insurance does patient-0001 have?",
  "threadId": "lookup-1"
}

### Lookup – patient details
POST {{baseUrl}}/api/copilot
Content-Type: application/json

{
  "query": "Show me patient-0002",
  "threadId": "lookup-2"
}

### Lookup – who manages a patient
POST {{baseUrl}}/api/copilot
Content-Type: application/json

{
  "query": "Who manages patient-0003?",
  "threadId": "lookup-3"
}

### Lookup – read a specific encounter
POST {{baseUrl}}/api/copilot
Content-Type: application/json

{
  "query": "Read encounter/encounter-0001",
  "threadId": "lookup-4"
}

### Lookup – coverage for a named patient
POST {{baseUrl}}/api/copilot
Content-Type: application/json

{
  "query": "What is the coverage for Alice Carter?",
  "threadId": "lookup-5"
}

# ─────────────────────────────────────────────
# Search Agent
# ─────────────────────────────────────────────

### Search – find patients by name
POST {{baseUrl}}/api/copilot
Content-Type: application/json

{
  "query": "Find patients named Carter",
  "threadId": "search-1"
}

### Search – list encounters for a patient
POST {{baseUrl}}/api/copilot
Content-Type: application/json

{
  "query": "List encounters for patient-0001",
  "threadId": "search-2"
}

### Search – find female patients
POST {{baseUrl}}/api/copilot
Content-Type: application/json

{
  "query": "Search for female patients",
  "threadId": "search-3"
}

### Search – patients by practitioner
POST {{baseUrl}}/api/copilot
Content-Type: application/json

{
  "query": "List patients managed by Dr Rao",
  "threadId": "search-4"
}

### Search – encounters by date range
POST {{baseUrl}}/api/copilot
Content-Type: application/json

{
  "query": "Find encounters for patient-0002 from January 2026 to March 2026",
  "threadId": "search-5"
}

# ─────────────────────────────────────────────
# Analytics Agent
# ─────────────────────────────────────────────

### Analytics – count diabetic patients
POST {{baseUrl}}/api/copilot
Content-Type: application/json

{
  "query": "How many diabetic patients do we have?",
  "threadId": "analytics-1"
}

### Analytics – total patient count
POST {{baseUrl}}/api/copilot
Content-Type: application/json

{
  "query": "Count all patients in the panel",
  "threadId": "analytics-2"
}

### Analytics – hypertension breakdown
POST {{baseUrl}}/api/copilot
Content-Type: application/json

{
  "query": "What percentage of patients have hypertension?",
  "threadId": "analytics-3"
}

### Analytics – condition comparison
POST {{baseUrl}}/api/copilot
Content-Type: application/json

{
  "query": "Compare the number of diabetes vs hypertension patients",
  "threadId": "analytics-4"
}

### Analytics – encounter volume
POST {{baseUrl}}/api/copilot
Content-Type: application/json

{
  "query": "What is the total volume of encounters in 2026?",
  "threadId": "analytics-5"
}

# ─────────────────────────────────────────────
# Clinical Agent
# ─────────────────────────────────────────────

### Clinical – full summary by ID
POST {{baseUrl}}/api/copilot
Content-Type: application/json

{
  "query": "Clinical summary for patient-0001",
  "threadId": "clinical-1"
}

### Clinical – summary by name
POST {{baseUrl}}/api/copilot
Content-Type: application/json

{
  "query": "Summarize Bob Nguyen's clinical history",
  "threadId": "clinical-2"
}

### Clinical – plain English narrative
POST {{baseUrl}}/api/copilot
Content-Type: application/json

{
  "query": "Tell me about patient-0003 in plain English",
  "threadId": "clinical-3"
}

### Clinical – what happened in a visit
POST {{baseUrl}}/api/copilot
Content-Type: application/json

{
  "query": "What happened during Alice Carter's last encounter?",
  "threadId": "clinical-4"
}

# ─────────────────────────────────────────────
# Cohort Agent
# ─────────────────────────────────────────────

### Cohort – diabetics without metformin
POST {{baseUrl}}/api/copilot
Content-Type: application/json

{
  "query": "Which diabetic patients are without metformin?",
  "threadId": "cohort-1"
}

### Cohort – patients at risk
POST {{baseUrl}}/api/copilot
Content-Type: application/json

{
  "query": "Flag patients with uncontrolled hypertension for review",
  "threadId": "cohort-2"
}

### Cohort – care gap identification
POST {{baseUrl}}/api/copilot
Content-Type: application/json

{
  "query": "Identify care gaps for diabetic patients who need an HbA1c test",
  "threadId": "cohort-3"
}

### Cohort – patients without recent encounters
POST {{baseUrl}}/api/copilot
Content-Type: application/json

{
  "query": "Who needs a follow-up? Find patients without an encounter in 2026",
  "threadId": "cohort-4"
}

# ─────────────────────────────────────────────
# Export Agent
# ─────────────────────────────────────────────

### Export – bulk export for group
POST {{baseUrl}}/api/copilot
Content-Type: application/json

{
  "query": "Export all data for the Northwind group",
  "threadId": "export-1"
}

### Export – download snapshot
POST {{baseUrl}}/api/copilot
Content-Type: application/json

{
  "query": "Bulk export patient and encounter data",
  "threadId": "export-2"
}

### Export – extract for analytics
POST {{baseUrl}}/api/copilot
Content-Type: application/json

{
  "query": "Extract a data snapshot of all resources for group-2026-northwind-atr-001",
  "threadId": "export-3"
}

# ─────────────────────────────────────────────
# Streaming (SSE)
# ─────────────────────────────────────────────

### Stream – clinical summary (POST keeps PHI out of URLs per FHIR R4 security guidance)
POST {{baseUrl}}/api/copilot/stream
Content-Type: application/json
Accept: text/event-stream

{
  "query": "Clinical summary for patient-0001",
  "threadId": "stream-1"
}

### Stream – analytics question
POST {{baseUrl}}/api/copilot/stream
Content-Type: application/json
Accept: text/event-stream

{
  "query": "How many diabetic patients do we have?",
  "threadId": "stream-2"
}

### Stream – cohort query
POST {{baseUrl}}/api/copilot/stream
Content-Type: application/json
Accept: text/event-stream

{
  "query": "Which patients are without metformin?",
  "threadId": "stream-3"
}

### Stream – search query
POST {{baseUrl}}/api/copilot/stream
Content-Type: application/json
Accept: text/event-stream

{
  "query": "Find patients named Carter",
  "threadId": "stream-4"
}

# ─────────────────────────────────────────────
# Multi-turn (same threadId)
# ─────────────────────────────────────────────

### Multi-turn 1 – initial question
POST {{baseUrl}}/api/copilot
Content-Type: application/json

{
  "query": "Summarize patient-0001",
  "threadId": "multi-turn-1"
}

### Multi-turn 2 – follow-up on same thread
POST {{baseUrl}}/api/copilot
Content-Type: application/json

{
  "query": "What medications are they on?",
  "threadId": "multi-turn-1"
}

### Multi-turn 3 – another follow-up
POST {{baseUrl}}/api/copilot
Content-Type: application/json

{
  "query": "Are there any care gaps?",
  "threadId": "multi-turn-1"
}
